---
layout: base.njk
title: Local Businesses
description: Discover local businesses in Newark-on-Trent
tags: []
eleventyExcludeFromCollections: true
permalink: /businesses/
---
<h1>Local Businesses</h1>
<p>Discover shops, restaurants, services, and more in Newark-on-Trent.</p>

<div class="filter-bar" aria-label="Filter businesses by category">
  <button class="filter-btn active" data-filter="all">All</button>
  {% set categories = [] %}
  {% for business in collections.business %}
    {% if business.data.category and business.data.category not in categories %}
      {% set categories = (categories.push(business.data.category), categories) %}
    {% endif %}
  {% endfor %}
  {% for cat in categories | sort %}
  <button class="filter-btn" data-filter="{{ cat }}">{{ cat }}</button>
  {% endfor %}
</div>

<div class="card-grid" id="business-grid">
  {% for business in collections.business %}
  <article class="card" data-category="{{ business.data.category }}">
    {% if business.data.photo %}
    <div class="card-image">
      <img src="{{ business.data.photo }}" alt="Photo of {{ business.data.name }}" loading="lazy">
    </div>
    {% endif %}
    <div class="card-body">
      {% if business.data.category %}<span class="category-tag">{{ business.data.category }}</span>{% endif %}
      <h3><a href="{{ business.url }}">{{ business.data.name }}</a></h3>
      <p>{{ business.data.description }}</p>
    </div>
  </article>
  {% endfor %}
</div>

<script>
(function () {
  var bar = document.querySelector('.filter-bar');
  if (!bar) return;
  bar.style.display = 'flex';
  bar.addEventListener('click', function (e) {
    var btn = e.target.closest('.filter-btn');
    if (!btn) return;
    bar.querySelector('.active').classList.remove('active');
    btn.classList.add('active');
    var filter = btn.getAttribute('data-filter');
    var cards = document.querySelectorAll('#business-grid .card');
    cards.forEach(function (card) {
      card.hidden = filter !== 'all' && card.getAttribute('data-category') !== filter;
    });
  });
})();
</script>
